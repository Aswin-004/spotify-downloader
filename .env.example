# Spotify API Credentials (required)
# Get these from https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=your_client_id_here
SPOTIFY_CLIENT_SECRET=your_client_secret_here

# Flask environment: "development" or "production"
FLASK_ENV=production

# Flask secret key for session security (change this to a random string)
SECRET_KEY=change-this-to-a-random-secret-key

# Base directory for all downloaded music
# Windows example: C:\Users\YourName\Music\DJ music
# Mac/Linux example: /home/yourname/Music/DJ music
BASE_DOWNLOAD_DIR=C:\Users\YourName\Music\DJ music

# Main playlist to auto-sync (Spotify playlist ID or full URL)
PLAYLIST_ID=your_playlist_id_here

# Ingest playlist for additional auto-downloads (optional, leave empty to disable)
INGEST_PLAYLIST_ID=

# OAuth redirect URI (must match your Spotify Developer Dashboard)
REDIRECT_URI=http://127.0.0.1:8888/callback

# Auto-sync check interval in seconds (default: 500)
CHECK_INTERVAL=500

# MongoDB connection (default: local Docker container)  # MUSICBRAINZ
MONGODB_URI=mongodb://localhost:27017  # MUSICBRAINZ
MONGODB_DB=spotify_downloader  # MUSICBRAINZ

# ── Telegram Notifications ──  # NOTIFICATION
TELEGRAM_BOT_TOKEN=your_bot_token_here  # NOTIFICATION
TELEGRAM_CHAT_ID=your_chat_id_here  # NOTIFICATION

# ── Discord Notifications ──  # NOTIFICATION
DISCORD_WEBHOOK_URL=your_webhook_url_here  # NOTIFICATION

# ── Notification Settings ──  # NOTIFICATION
NOTIFY_ON_SUCCESS=true  # NOTIFICATION
NOTIFY_ON_FAILURE=true  # NOTIFICATION
NOTIFY_ON_PLAYLIST_COMPLETE=true  # NOTIFICATION
NOTIFY_STORAGE_THRESHOLD_MB=5000  # NOTIFICATION
